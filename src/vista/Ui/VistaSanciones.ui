   <string notr="true">#Dialog {
    background-color: #89ABA7;
}

* {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-size: 13px;
}

QFrame#frame_principal {
    background-color: white;
    border: 2px solid #e5e7eb;
    border-radius: 15px;
}
QTableWidget::item:selected {
    background-color: #dbeafe; 
    color: #1e40af;
}

QComboBox QAbstractItemView {
    background-color: white;
    selection-background-color: #1f2937; 
    selection-color: white; 
}

QLineEdit, QComboBox {
    border: 1px solid #ced4da;
    border-radius: 5px;
    padding: 5px;
    background-color: white;
    color: #333;
}

QLineEdit {
    border: 2px solid #bdc3c7;
    border-radius: 15px; 
    padding: 5px 15px;
    background: white;
    selection-background-color: #34495e;
}


QTableWidget {
    border: 1px solid #d1d5db;
    border-radius: 10px; 
    gridline-color: #f3f4f6;
}
/* Estilo para las cabeceras de la tabla */
QHeaderView::section {
    background-color: #2c3e50;
    color: white;
    padding: 5px;
    border: none;
    font-weight: bold;
}


QPushButton#boton_buscar {
    background-color: #bdc3c7;
    color: white;
    border-radius: 10px;
    padding: 5px;
}

QPushButton#boton_buscar:hover {
    background-color: #d5dbdb;
}

QPushButton#boton_buscar:pressed {
    background-color: #7f8c8d;
}

QHeaderView::section:last {
    border-top-right-radius: 5px;
}

QHeaderView::section:first {
    border-top-left-radius: 5px;
}

QHeaderView::section {
    background-color: #1f2937; 
    color: #ffffff; /* Texto blanco */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 15px;
    font-weight: bold; /* Negrita */
    padding: 6px;
    border: none;
    border-right: 1px solid #374151; /* Una pequeña línea divisoria entre títulos */
}

